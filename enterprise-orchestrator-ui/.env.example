# API runtime
APP_NAME=enterprise-orchestrator-ui
APP_ENV=dev
APP_PORT=8080

# Storage
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/orchestrator

# Queue
REDIS_URL=redis://localhost:6379/0

# Retry policy
JOB_MAX_RETRIES=3
JOB_RETRY_BASE_DELAY=30
JOB_RETRY_MAX_DELAY=300
JOB_TIMEOUT=1800

# SharePoint (Phase 1) — service principal (app-only) auth
SHAREPOINT_TENANT_ID=your-azure-tenant-id
SHAREPOINT_CLIENT_ID=your-app-registration-client-id
SHAREPOINT_CLIENT_SECRET=your-client-secret
SHAREPOINT_TENANT_URL=https://your-org.sharepoint.com
SHAREPOINT_SITE_PATH=/teams/YourTeam/YourFolder
SHAREPOINT_LIBRARY=Shared Documents
SHAREPOINT_TARGET_FOLDER=2026/Report_Automation

# Confluence (Primary publisher) — uses ~/.atlassian/credentials.json automatically
CONFLUENCE_BASE_URL=https://your-org.atlassian.net/wiki
CONFLUENCE_SPACE_KEY=YOUR-SPACE-KEY
CONFLUENCE_PARENT_PAGE_ID=YOUR-CONFLUENCE-PAGE-ID
# Leave these empty to auto-read from ~/.atlassian/credentials.json
CONFLUENCE_USER_EMAIL=
CONFLUENCE_API_TOKEN=
